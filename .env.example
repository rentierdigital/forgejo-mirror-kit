# --- Forgejo Mirror Kit --- Environment Variables ---
# Copy this file: cp .env.example .env
# Edit the 3 values below. That's it.

# The domain your Forgejo instance will be reachable at.
FORGEJO_DOMAIN=localhost

# SSH port for git clone via SSH (mapped from container to host).
FORGEJO_SSH_PORT=2222

# PostgreSQL password --- generate a strong one.
# Example: openssl rand -base64 24
POSTGRES_PASSWORD=changeme-generate-a-real-password

# How often Forgejo checks for upstream changes (in hours).
# Default: 8h. Minimum: 1h. Lower = more API calls to GitHub.
MIRROR_INTERVAL=8
